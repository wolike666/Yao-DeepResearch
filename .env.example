# OpenAI-compatible API settings
OPENAI_API_KEY=
OPENAI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen-plus-latest

# Alibaba-compatible fallback fields (optional)
# If OPENAI_* is empty, config will fallback to these fields.
# API_KEY=
# API_BASE=
# INFER_MODEL_NAME=
# MODEL_PATH=

# Optional: reuse env from sibling Alibaba-NLP-DeepResearch project.
# If set, tools will load this file and reuse keys such as SERPER_KEY_ID/JINA_API_KEYS.
# ALIBABA_ENV_PATH=F:/Code/LLM/Alibaba-NLP-DeepResearch/.env

# Optional direct keys (if not using ALIBABA_ENV_PATH)
SERPER_KEY_ID=
JINA_API_KEYS=

# Engine settings
# Cost profile: low (cheapest), standard (balanced), high (best quality)
COST_MODE=standard
# Optional explicit overrides. Leave empty to follow COST_MODE defaults.
MAX_STEPS=
MAX_SEARCH_RESULTS=
MAX_PAGE_CHARS=
MAX_SCHOLAR_RESULTS=
SEARCH_MODE=hybrid
SOURCE_POLICY=balanced

# Single-run script defaults (scripts/run_single_research_windows.py)
QUESTION=
OUTPUT_PATH=outputs
